# Database (use port 5433 for local dev with docker-compose, port 5432 for production)
DATABASE_URL=postgresql://bcard:bcard@localhost:5433/bcard

# NextAuth
AUTH_URL=https://cards.example.com
AUTH_SECRET=generate-me-with-openssl-rand-base64-32

# OpenID Connect
# Redirect URI for your OIDC provider: {AUTH_URL}/api/auth/callback/authentik
AUTH_OIDC_ISSUER=https://auth.example.com/application/o/bcard
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=

# Role groups (from Authentik groups scope)
GROUP_USER=bcards user
GROUP_ADMIN=bcards admin

# App
NEXT_PUBLIC_APP_URL=https://cards.example.com
NEXT_PUBLIC_COMPANY_DEFAULT=ASYA
